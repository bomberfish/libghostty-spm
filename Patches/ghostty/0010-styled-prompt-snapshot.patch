+/// Returns the left prompt portion of the newest semantic prompt. This relies
+/// on OSC 133 shell integration and returns null until a prompt has begun.
+pub fn latestPromptSelection(self: *Screen) ?Selection {
+    if (!self.semantic_prompt.seen) return null;
+
+    const bottom = self.pages.getBottomRight(.screen) orelse return null;
+    var prompts = bottom.promptIterator(.left_up, null);
+    const prompt_row = prompts.next() orelse return null;
+
+    var start: ?Pin = null;
+    var end: ?Pin = null;
+    var cells = prompt_row.cellIterator(.right_down, null);
+    while (cells.next()) |pin| {
+        const cell = pin.rowAndCell().cell;
+        switch (cell.semantic_content) {
+            .prompt => {
+                if (start == null and cell.hasText()) start = pin;
+                if (start != null) end = pin;
+            },
+            .input => break,
+            .output => if (start != null and pin.y != prompt_row.y) break,
+        }
+    }
+
+    return Selection.init(start orelse return null, end orelse return null, false);
+}
