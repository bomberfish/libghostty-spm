+    /// Read the newest OSC 133 prompt with its terminal styling encoded as VT
+    /// SGR sequences. Returns false until shell integration marks a prompt.
+    export fn ghostty_surface_read_latest_prompt(
+        surface: *Surface,
+        result: *Text,
+    ) bool {
+        const core_surface = &surface.core_surface;
+        core_surface.renderer_state.mutex.lock();
+        defer core_surface.renderer_state.mutex.unlock();
+
+        const screen = core_surface.io.terminal.screens.active;
+        const selection = screen.latestPromptSelection() orelse return false;
+        var writer: std.Io.Writer.Allocating = .init(global.alloc);
+        defer writer.deinit();
+
+        var formatter: terminal.formatter.ScreenFormatter = .init(screen, .{
+            .emit = .vt,
+            .unwrap = true,
+            .trim = true,
+            .background = core_surface.io.terminal.colors.background.get(),
+            .foreground = core_surface.io.terminal.colors.foreground.get(),
+            .palette = &core_surface.io.terminal.colors.palette.current,
+        });
+        formatter.content = .{ .selection = selection };
+        formatter.format(&writer.writer) catch |err| {
+            log.warn("error reading styled prompt err={}", .{err});
+            return false;
+        };
+        const text = writer.toOwnedSliceSentinel(0) catch |err| {
+            log.warn("error allocating styled prompt err={}", .{err});
+            return false;
+        };
+
+        result.* = .{
+            .tl_px_x = -1,
+            .tl_px_y = -1,
+            .offset_start = 0,
+            .offset_len = 0,
+            .text = text.ptr,
+            .text_len = text.len,
+        };
+        return true;
+    }
